{
  "id": null,
  "uid": "eink-bridge",
  "title": "E-Ink Bridge",
  "tags": ["eink"],
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Sessions",
      "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "eink_sessions_active",
          "legendFormat": "active"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active WS Connections",
      "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "eink_ws_connections_active",
          "legendFormat": "ws"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Sessions Created (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "eink_sessions_created_total",
          "legendFormat": "created"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Sessions Submitted (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "eink_sessions_submitted_total",
          "legendFormat": "submitted"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Session Lifecycle Rates",
      "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "rate(eink_sessions_created_total[5m])",
          "legendFormat": "created/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "rate(eink_sessions_submitted_total[5m])",
          "legendFormat": "submitted/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "rate(eink_sessions_cancelled_total[5m])",
          "legendFormat": "cancelled/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "rate(eink_sessions_expired_total[5m])",
          "legendFormat": "expired/s"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Request Rate by Path",
      "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "sum(rate(eink_http_requests_total[5m])) by (path, method)",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 5 },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP Latency Percentiles",
      "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "histogram_quantile(0.50, sum(rate(eink_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p50 {{path}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "histogram_quantile(0.95, sum(rate(eink_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p95 {{path}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "histogram_quantile(0.99, sum(rate(eink_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p99 {{path}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "OCR Duration Percentiles",
      "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "histogram_quantile(0.50, sum(rate(eink_ocr_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "histogram_quantile(0.90, sum(rate(eink_ocr_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p90"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "histogram_quantile(0.99, sum(rate(eink_ocr_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "OCR Request Rate & Tokens",
      "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "rate(eink_ocr_requests_total{result=\"ok\"}[5m])",
          "legendFormat": "ok/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "rate(eink_ocr_requests_total{result=\"error\"}[5m])",
          "legendFormat": "error/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "rate(eink_ocr_tokens_total[5m])",
          "legendFormat": "{{kind}} tokens/s"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "WebSocket & Long-poll",
      "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "eink_ws_connections_active",
          "legendFormat": "WS active"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "rate(eink_long_poll_total{result=\"notified\"}[5m])",
          "legendFormat": "poll notified/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "rate(eink_long_poll_total{result=\"timeout\"}[5m])",
          "legendFormat": "poll timeout/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "rate(eink_webhook_total[5m])",
          "legendFormat": "webhook {{result}}/s"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Session Content Size Distribution",
      "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "histogram_quantile(0.50, sum(rate(eink_session_content_bytes_bucket[30m])) by (le))",
          "legendFormat": "p50 bytes"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "histogram_quantile(0.95, sum(rate(eink_session_content_bytes_bucket[30m])) by (le))",
          "legendFormat": "p95 bytes"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "bytes"
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Android App Metrics (via Pushgateway)",
      "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "eink_android_ocr_requests_total{result=\"ok\"}",
          "legendFormat": "OCR ok"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "eink_android_ocr_requests_total{result=\"error\"}",
          "legendFormat": "OCR error"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "eink_android_submissions_total{result=\"ok\"}",
          "legendFormat": "submit ok"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "eink_android_submissions_total{result=\"error\"}",
          "legendFormat": "submit error"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "eink_android_sessions_viewed_total",
          "legendFormat": "sessions viewed"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "eink_android_ws_connections_total",
          "legendFormat": "WS connections"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "CLI Metrics (via Pushgateway)",
      "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "eink_cli_commands_total",
          "legendFormat": "{{command}} {{result}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "eink_cli_duration_seconds",
          "legendFormat": "{{command}} {{result}} duration"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "HTTP Error Rate by Status",
      "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 39 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-eink" },
          "expr": "sum(rate(eink_http_requests_total[5m])) by (status)",
          "legendFormat": "HTTP {{status}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "reqps"
        }
      }
    }
  ]
}
